{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["sjtweaks-staff/**"]
  },
  "deploy": {
    "startCommand": "cd sjtweaks-staff && npm install && node server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
